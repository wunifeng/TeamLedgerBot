# ============================================================
# TeamLedgerBot Backend — Environment Variables Example
# Copy this file to .env and fill in your values
# ============================================================

# Database (Neon PostgreSQL — async driver)
DATABASE_URL=postgresql+asyncpg://user:password@neon-host.neon.tech/dbname?sslmode=require

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890

# Application
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

# Timezone (display only — DB stores UTC)
TIMEZONE=Asia/Bangkok

# Bundled salary rules and local receipt storage
# SALARY_CONFIG_PATH=/app/app/data/salary_config.json
# UPLOAD_DIR=/app/uploads

# Risk Alert Thresholds
RISK_HIGH_AMOUNT_THRESHOLD=10000
RISK_DUPLICATE_WINDOW_SECONDS=300
RISK_FREQUENCY_LIMIT=5
RISK_FREQUENCY_WINDOW_SECONDS=600
